seen_at": "2026-05-29", "last_seen_at": "2026-06-01", "position_id": "naval_recent_six.position.max_hodak", "representative_claims": ["The thing AI hasn’t come to yet, but I think it will within the next year—probably within 2026—and that will be very exciting: right now it can generate software, but soon it will generate STEP files and PCB layouts.", "We have a big internal fine-tune of 3.2 that I use for a bunch of things—we’re going to look into porting to 4 soon.", "That will allow them to sell these things for $10,000 instead of $100,000.", "Now it’s going to be 70% agency, 30% intelligence—and that’ll shift further as the models get better.", "The consensus in Silicon Valley is that regulation sucks — we want to go faster, we want to realize this amazing future, we want abundance, prosperity, and stuff that slows down that future is to be avoided.", "Two, you need to prevent the global regulator from casting doubt on what might happen with their clinical trial if they give you some.", "If AI is booming and there are major advances, and two years from now we’re spending ten times as much on AI, this could be great.", "If you’re a really capable developer, these things are really powerful."], "source_family_ids": ["naval_frontier_founders_industrial_2026"], "speaker": "Max Hodak", "speaker_status": "source_provided", "themes": ["geopolitics", "ai_capability_and_agi", "time_compute_substitution", "software_production", "institutional_change", "regulation", "future_of_work", "hardware_engineering", "startup_organization", "ai_coding_agents", "recruiting_and_culture", "judgment", "truth_and_credibility", "token_economics", "vertical_integration", "accountability", "persuasion_and_sales"]}
