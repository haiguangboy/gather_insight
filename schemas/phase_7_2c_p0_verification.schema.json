{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatherinsight.local/schemas/phase_7_2c_p0_verification.schema.json",
  "type": "object",
  "required": ["schema_version", "queue_id", "theme_claim_ids", "risk_source_claim_ids", "risk_evidence_ids", "risk_text_spans", "risk_token", "risk_type", "conclusion_impact", "why_conclusion_changing", "source_fidelity_status", "external_fact_status"],
  "properties": {
    "schema_version": {"const": "phase_7_2c_v1"},
    "queue_id": {"type": "string", "minLength": 1},
    "theme_claim_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "risk_source_claim_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "risk_evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "risk_text_spans": {"type": "array", "items": {"type": "object"}, "minItems": 1},
    "risk_token": {"type": "string", "minLength": 1},
    "risk_type": {"enum": ["numeric", "entity", "negation", "epistemic_scope", "causal_scope", "speaker"]},
    "conclusion_impact": {"enum": ["high", "medium", "low"]},
    "why_conclusion_changing": {"type": "string", "minLength": 1},
    "source_fidelity_status": {"enum": ["pending", "verified", "corrected", "rejected", "not_applicable"]},
    "external_fact_status": {"enum": ["not_required", "not_checked", "verified", "contradicted", "insufficient_evidence"]}
  },
  "additionalProperties": true
}
