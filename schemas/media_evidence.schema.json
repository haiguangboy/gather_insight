{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gather-insight.local/schemas/media_evidence.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["evidence_id", "media_id", "source_type", "provider", "speaker", "speaker_confidence", "attribution_method", "start_seconds", "end_seconds", "timestamp", "youtube_url", "quote", "summary_zh", "relevance", "needs_review"],
    "properties": {
      "evidence_id": {"type": "string", "pattern": "^.+\\.ev_[0-9]{4}$"},
      "media_id": {"type": "string"},
      "source_type": {"type": "string"},
      "provider": {"type": "string"},
      "speaker": {"type": "string"},
      "speaker_confidence": {"type": "number", "minimum": 0, "maximum": 1},
      "attribution_method": {"type": "string"},
      "start_seconds": {"type": "number", "minimum": 0},
      "end_seconds": {"type": "number", "minimum": 0},
      "timestamp": {"type": "string"},
      "youtube_url": {"type": "string", "format": "uri"},
      "section": {"type": ["string", "null"]},
      "quote": {"type": "string", "maxLength": 500},
      "summary_zh": {"type": "string"},
      "relevance": {"type": "string"},
      "needs_review": {"type": "boolean"}
    },
    "additionalProperties": false
  }
}
