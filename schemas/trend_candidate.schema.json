{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gather-insight.local/schemas/trend_candidate.schema.json",
  "type": "object",
  "required": [
    "candidate_id", "topic", "claim", "why_valuable", "novelty_type",
    "non_consensus_signal", "trend_implication", "supporting_text",
    "source_ranges", "source_agreement", "entity_risks", "numeric_risks",
    "speaker_status", "needs_verification"
  ],
  "properties": {
    "candidate_id": {"type": "string"},
    "topic": {"type": "string"},
    "topic_key": {"type": "string"},
    "claim": {"type": "string"},
    "why_valuable": {"type": "string"},
    "novelty_type": {"type": "string"},
    "non_consensus_signal": {"type": "array", "items": {"type": "string"}},
    "trend_implication": {"type": "string"},
    "supporting_text": {"type": "string"},
    "source_ranges": {"type": "array", "items": {"type": "object"}},
    "source_agreement": {"type": "string"},
    "entity_risks": {"type": "array", "items": {"type": "string"}},
    "numeric_risks": {"type": "array", "items": {"type": "string"}},
    "negation_risks": {"type": "array", "items": {"type": "string"}},
    "speaker": {"type": ["string", "null"]},
    "speaker_status": {"enum": ["source_provided", "audio_confirmed", "section_inferred", "probable", "boundary_uncertain", "unknown"]},
    "speaker_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "attribution_scope": {"type": "string"},
    "exact_quote_allowed": {"type": "boolean"},
    "needs_verification": {"type": "boolean"}
  },
  "additionalProperties": true
}
