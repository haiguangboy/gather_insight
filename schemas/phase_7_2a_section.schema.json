{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatherinsight.local/schemas/phase_7_2a_section.schema.json",
  "title": "Phase 7.2A official source section",
  "type": "object",
  "required": ["schema_version", "section_id", "source_id", "source_family_id", "independence_group_id", "site_rank", "chronological_index", "title", "published_at", "section_title", "section_order", "speaker", "speaker_status", "text", "source_url", "html_range", "source_hash", "content_hash", "duplicate_cluster_id"],
  "properties": {
    "schema_version": {"const": "phase_7_2a_v1"},
    "section_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_family_id": {"type": "string", "minLength": 1},
    "independence_group_id": {"type": "string", "minLength": 1},
    "site_rank": {"type": "integer", "minimum": 1, "maximum": 6},
    "chronological_index": {"type": "integer", "minimum": 1, "maximum": 6},
    "title": {"type": "string", "minLength": 1},
    "published_at": {"type": "string", "format": "date"},
    "section_title": {"type": "string", "minLength": 1},
    "section_order": {"type": "integer", "minimum": 1},
    "speaker": {"type": "string", "minLength": 1},
    "speaker_status": {"enum": ["source_provided", "unknown"]},
    "text": {"type": "string", "minLength": 1},
    "source_url": {"type": "string", "format": "uri"},
    "html_range": {"type": "object", "required": ["char_start", "char_end"], "properties": {"char_start": {"type": "integer", "minimum": 0}, "char_end": {"type": "integer", "minimum": 1}}, "additionalProperties": false},
    "source_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "duplicate_cluster_id": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
