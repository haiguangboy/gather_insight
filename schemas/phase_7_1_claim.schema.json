{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gather-insight.local/schemas/phase_7_1_claim.schema.json",
  "type": "object",
  "required": ["schema_version", "claim_id", "media_id", "claim", "claim_type", "value_types", "themes", "source_record_ids", "evidence_ids", "source_time_start", "source_time_end", "source_url", "confidence", "novelty_score", "importance_score", "non_consensus_score", "entity_risks", "numeric_risks", "negation_risks", "needs_verification", "exact_quote_allowed", "extraction_method", "created_at", "source_hashes"],
  "properties": {
    "schema_version": {"const": "phase_7_1_claim_v1"},
    "claim_id": {"type": "string"},
    "media_id": {"type": "string"},
    "claim": {"type": "string", "minLength": 1},
    "claim_type": {"enum": ["fact", "prediction", "causal_claim", "technical_mechanism", "engineering_constraint", "failure_mode", "conditional_conclusion", "comparison", "opinion", "open_question"]},
    "value_types": {"type": "array", "items": {"enum": ["trend_signal", "non_consensus", "route_change", "hidden_assumption", "quantitative_signal", "boundary_condition", "failure_case", "practical_implication", "cross_source_connection"]}},
    "themes": {"type": "array", "items": {"type": "string"}},
    "speaker": {"type": ["string", "null"]},
    "speaker_status": {"type": "string"},
    "speaker_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "attribution_scope": {"type": "string"},
    "source_record_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "source_time_start": {"type": "number"},
    "source_time_end": {"type": "number"},
    "source_url": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "novelty_score": {"type": "number", "minimum": 0, "maximum": 1},
    "importance_score": {"type": "number", "minimum": 0, "maximum": 1},
    "non_consensus_score": {"type": "number", "minimum": 0, "maximum": 1},
    "entity_risks": {"type": "array", "items": {"type": "string"}},
    "numeric_risks": {"type": "array", "items": {"type": "string"}},
    "negation_risks": {"type": "array", "items": {"type": "string"}},
    "needs_verification": {"type": "boolean"},
    "exact_quote_allowed": {"type": "boolean"},
    "extraction_method": {"type": "string"},
    "created_at": {"type": "string"},
    "source_hashes": {"type": "object", "additionalProperties": {"type": "string"}},
    "claim_summary": {"type": "string"},
    "judge_metadata": {"type": "object"}
  },
  "additionalProperties": true
}
