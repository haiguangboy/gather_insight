{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatherinsight.local/schemas/phase_7_2a_source_claim.schema.json",
  "title": "Phase 7.2A speaker-attributed source claim",
  "type": "object",
  "required": ["schema_version", "claim_id", "source_id", "source_family_id", "independence_group_id", "speaker", "speaker_status", "attribution_scope", "claim", "claim_type", "value_types", "themes", "evidence_ids", "source_section_ids", "published_at", "confidence", "importance_score", "novelty_score", "non_consensus_score", "exact_quote_allowed", "verification_status", "extraction_method", "model_and_prompt_version"],
  "properties": {
    "schema_version": {"const": "phase_7_2a_v1"},
    "claim_id": {"type": "string", "minLength": 1},
    "source_id": {"type": "string", "minLength": 1},
    "source_family_id": {"type": "string", "minLength": 1},
    "independence_group_id": {"type": "string", "minLength": 1},
    "speaker": {"type": "string", "minLength": 1},
    "speaker_status": {"const": "source_provided"},
    "attribution_scope": {"enum": ["speaker_direct_claim", "speaker_personal_experience", "host_question", "host_summary", "speaker_prediction", "speaker_hypothesis", "multi_speaker_consensus", "system_synthesis"]},
    "claim": {"type": "string", "minLength": 1},
    "claim_type": {"enum": ["fact", "prediction", "causal_claim", "technical_mechanism", "engineering_constraint", "failure_mode", "conditional_conclusion", "comparison", "opinion", "open_question", "normative_claim", "strategic_advice", "personal_experience", "institutional_claim", "geopolitical_claim"]},
    "value_types": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "themes": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "source_section_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "published_at": {"type": "string", "format": "date"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "importance_score": {"type": "number", "minimum": 0, "maximum": 1},
    "novelty_score": {"type": "number", "minimum": 0, "maximum": 1},
    "non_consensus_score": {"type": "number", "minimum": 0, "maximum": 1},
    "exact_quote_allowed": {"type": "boolean"},
    "verification_status": {"type": "string"},
    "extraction_method": {"type": "string"},
    "model_and_prompt_version": {"type": "string"}
  },
  "additionalProperties": true
}
