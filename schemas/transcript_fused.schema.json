{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gather-insight.local/schemas/transcript_fused.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "segment_id",
      "media_id",
      "speaker",
      "chapter",
      "start_seconds",
      "end_seconds",
      "text",
      "text_ulisten_raw",
      "structure_source",
      "text_source",
      "alignment_method",
      "alignment_confidence",
      "needs_review",
      "youtube_url",
      "fusion_mode",
      "review_reasons"
    ],
    "properties": {
      "segment_id": {"type": "string", "pattern": "^yt_[A-Za-z0-9_-]+\\.seg_[0-9]{4}$"},
      "media_id": {"type": "string", "pattern": "^yt_[A-Za-z0-9_-]+$"},
      "speaker": {"type": ["string", "null"]},
      "chapter": {"type": ["string", "null"]},
      "chapter_index": {"type": ["integer", "null"], "minimum": 1},
      "reference_url": {"type": ["string", "null"]},
      "start_seconds": {"type": "number", "minimum": 0},
      "end_seconds": {"type": "number", "minimum": 0},
      "text": {"type": "string"},
      "text_ulisten_raw": {"type": ["string", "null"]},
      "text_usetranscribe_raw": {"type": ["string", "null"]},
      "text_official_raw": {"type": ["string", "null"]},
      "structure_source": {"enum": ["ulisten_manual_browser_copy", "official_transcript", "text_timeline"]},
      "text_source": {"enum": ["usetranscribe_manual_export", "usetranscribe_format_fixture", "official_transcript", "official_transcript_format_fixture", "ulisten_raw_degraded", "ulisten_raw_review_fallback", "spacing_reconstruction_fixture"]},
      "source_is_fixture": {"type": "boolean"},
      "alignment_method": {"enum": ["timestamp_plus_normalized_text", "constrained_monotonic_semantic_alignment", "vecalign_monotonic_dp", "sentalign_monotonic_dp", "single_source_degraded", "single_source_no_alignment", "fixture_passthrough"]},
      "alignment_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
      "needs_review": {"type": "boolean"},
      "youtube_url": {"type": "string"},
      "fusion_mode": {"enum": ["dual_source", "official_dual", "official_single", "text_single", "structure_degraded", "failed", "degraded", "fixture"]},
      "review_reasons": {"type": "array", "items": {"type": "string"}},
      "speaker_needs_review": {"type": "boolean"},
      "speaker_status": {"enum": ["source_provided", "unknown_needs_review"]},
      "speaker_review_reasons": {"type": "array", "items": {"type": "string"}},
      "text_status": {"enum": ["readable", "raw_structure_only", "empty"]},
      "structure_status": {"enum": ["source_provided", "text_timeline_only"]},
      "alignment_components": {
        "type": ["object", "null"],
        "properties": {
          "normalized_text_similarity": {"type": "number", "minimum": 0, "maximum": 1},
          "time_overlap_score": {"type": "number", "minimum": 0, "maximum": 1},
          "chapter_consistency": {"type": "number", "minimum": 0, "maximum": 1},
          "semantic_similarity": {"type": "number", "minimum": 0, "maximum": 1},
          "lexical_anchor_score": {"type": "number", "minimum": 0, "maximum": 1},
          "entity_consistency_score": {"type": "number", "minimum": 0, "maximum": 1},
          "time_prior_score": {"type": "number", "minimum": 0, "maximum": 1},
          "sequence_context_score": {"type": "number", "minimum": 0, "maximum": 1},
          "raw_cosine": {"type": ["number", "null"], "minimum": -1, "maximum": 1},
          "margin_score": {"type": ["number", "null"]}
        },
        "additionalProperties": false
      },
      "conflicts": {"type": "array", "items": {"type": "object"}}
    },
    "additionalProperties": true
  }
}
