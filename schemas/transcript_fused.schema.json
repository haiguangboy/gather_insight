{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gather-insight.local/schemas/transcript_fused.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "segment_id",
      "media_id",
      "speaker",
      "chapter",
      "start_seconds",
      "end_seconds",
      "text",
      "text_ulisten_raw",
      "structure_source",
      "text_source",
      "alignment_method",
      "alignment_confidence",
      "needs_review",
      "youtube_url",
      "fusion_mode",
      "review_reasons"
    ],
    "properties": {
      "segment_id": {"type": "string", "pattern": "^yt_[A-Za-z0-9_-]+\\.seg_[0-9]{4}$"},
      "media_id": {"type": "string", "pattern": "^yt_[A-Za-z0-9_-]+$"},
      "speaker": {"type": "string", "minLength": 1},
      "chapter": {"type": "string", "minLength": 1},
      "chapter_index": {"type": "integer", "minimum": 1},
      "reference_url": {"type": ["string", "null"]},
      "start_seconds": {"type": "number", "minimum": 0},
      "end_seconds": {"type": "number", "minimum": 0},
      "text": {"type": "string"},
      "text_ulisten_raw": {"type": "string"},
      "text_usetranscribe_raw": {"type": ["string", "null"]},
      "structure_source": {"const": "ulisten_manual_browser_copy"},
      "text_source": {"enum": ["usetranscribe_manual_export", "ulisten_raw_degraded", "spacing_reconstruction_fixture"]},
      "alignment_method": {"enum": ["timestamp_plus_normalized_text", "single_source_degraded", "fixture_passthrough"]},
      "alignment_confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
      "needs_review": {"type": "boolean"},
      "youtube_url": {"type": "string"},
      "fusion_mode": {"enum": ["dual_source", "degraded", "fixture"]},
      "review_reasons": {"type": "array", "items": {"type": "string"}},
      "alignment_components": {
        "type": ["object", "null"],
        "properties": {
          "normalized_text_similarity": {"type": "number", "minimum": 0, "maximum": 1},
          "time_overlap_score": {"type": "number", "minimum": 0, "maximum": 1},
          "chapter_consistency": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": false
      },
      "conflicts": {"type": "array", "items": {"type": "object"}}
    },
    "additionalProperties": true
  }
}
