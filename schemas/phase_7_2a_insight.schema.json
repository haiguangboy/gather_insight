{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatherinsight.local/schemas/phase_7_2a_insight.schema.json",
  "title": "Phase 7.2A trend or system insight",
  "type": "object",
  "required": ["insight_id", "insight_type", "statement", "supporting_claim_ids", "supporting_evidence_ids", "supporting_source_ids", "independent_source_family_count", "speakers", "first_seen_at", "last_seen_at", "counter_claim_ids", "conditions", "uncertainty", "confidence", "inference_method", "verification_status", "publishability"],
  "properties": {
    "insight_id": {"type": "string", "minLength": 1},
    "insight_type": {"enum": ["single_source_signal", "repeated_speaker_position", "cross_source_pattern", "emerging_trend", "causal_synthesis", "industry_implication", "hypothesis", "unresolved_tension"]},
    "statement": {"type": "string", "minLength": 1},
    "supporting_claim_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "supporting_evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "supporting_source_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "independent_source_family_count": {"type": "integer", "minimum": 1},
    "speakers": {"type": "array", "items": {"type": "string"}},
    "first_seen_at": {"type": "string", "format": "date"},
    "last_seen_at": {"type": "string", "format": "date"},
    "counter_claim_ids": {"type": "array", "items": {"type": "string"}},
    "conditions": {"type": "array", "items": {"type": "string"}},
    "uncertainty": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "inference_method": {"type": "string"},
    "verification_status": {"type": "string"},
    "publishability": {"type": "string"}
  },
  "additionalProperties": false
}
